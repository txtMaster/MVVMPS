<ResourceDictionary
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:sys="clr-namespace:System;assembly=mscorlib">
  <!--  VARIABLES  -->

  <Color x:Key="WhiteGrayColor">#D6E7FE</Color>
  <Color x:Key="DarkGrayColor">#8391A3</Color>
  <Color x:Key="BaseWhiteColor">#F2F7FF</Color>

  <sys:Double x:Key="SmallFontSize">8</sys:Double>
  <sys:Double x:Key="BaseFontSize">12</sys:Double>
  <sys:Double x:Key="MediumFontSize">16</sys:Double>
  <sys:Double x:Key="LargeFontSize">20</sys:Double>
  <sys:Double x:Key="XLFontSize">40</sys:Double>
  <sys:Double x:Key="XXLFontSize">80</sys:Double>
  <Thickness x:Key="TinySpace">4</Thickness>
  <Thickness x:Key="SmallSpace">8</Thickness>
  <Thickness x:Key="BaseSpace">12</Thickness>
  <Thickness x:Key="BaseSpace-Y">0,12</Thickness>
  <Thickness x:Key="BaseSpace-X">12,0</Thickness>
  <Thickness x:Key="BaseSpace-Bottom">0,0,0,12</Thickness>

  <Thickness x:Key="MediumSpace">16</Thickness>
  <Thickness x:Key="MediumSpace-X">16,0</Thickness>
  <Thickness x:Key="MediumSpace-Right">16,0,0,0</Thickness>

  <Thickness x:Key="HighSpace">20</Thickness>
  <Thickness x:Key="HighSpaceLine">20,0</Thickness>

  <CornerRadius x:Key="BaseRadius">12</CornerRadius>
  <CornerRadius x:Key="BaseRadius-Top">12,12,0,0</CornerRadius>
  <CornerRadius x:Key="BaseRadius-Bottom">0,0,12,12</CornerRadius>
  <CornerRadius x:Key="MediumRadius">16</CornerRadius>
  <CornerRadius x:Key="HighRadius">20</CornerRadius>

  <SolidColorBrush x:Key="BaseWhite" Color="{StaticResource BaseWhiteColor}" />
  <SolidColorBrush x:Key="WhiteGray" Color="{StaticResource WhiteGrayColor}" />
  <SolidColorBrush x:Key="BaseGray" Color="#BFCFE6" />
  <SolidColorBrush x:Key="DarkGray" Color="{StaticResource DarkGrayColor}" />
  <SolidColorBrush x:Key="BaseBlue" Color="#6C9BE2" />
  <SolidColorBrush x:Key="DarkBlue" Color="#5F6F83" />


  <SolidColorBrush x:Key="BaseRed" Color="#B57171" />
  <SolidColorBrush x:Key="BaseGreen" Color="#71B57B" />

  <SolidColorBrush x:Key="VerdeClaro" Color="#A9DAB0" />
  <SolidColorBrush x:Key="VerdeBlanco" Color="#C9EECF" />
  <SolidColorBrush x:Key="Blanco" Color="#FFFFFF" />

  <SolidColorBrush x:Key="Azul" Color="#558CD4" />
  <SolidColorBrush x:Key="AzulClaro" Color="#9FC6FF" />
  <SolidColorBrush x:Key="AzulBlanco" Color="#D2E4FF" />

  <SolidColorBrush x:Key="GrisOscuro" Color="#3A3A3A" />
  <SolidColorBrush x:Key="GrisClaro" Color="#DCE4EE" />
  <SolidColorBrush x:Key="GrisBlanco" Color="#EEF3F8" />
  
  <SolidColorBrush x:Key="BaseForeground" Color="{StaticResource DarkGrayColor}" />
  <SolidColorBrush x:Key="BaseBackground" Color="{StaticResource BaseWhiteColor}"/>

  <Style TargetType="UserControl">
    <Setter Property="Background" Value="{StaticResource Blanco}" />
    <Setter Property="Foreground" Value="{StaticResource DarkGray}" />
  </Style>
  <Style TargetType="RadioButton">
    <Setter Property="Foreground" Value="{StaticResource BaseForeground}" />
    <Setter Property="VerticalAlignment" Value="Center" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="RadioButton">
          <StackPanel
            VerticalAlignment="{TemplateBinding VerticalAlignment}"
            Background="{TemplateBinding Background}"
            Orientation="Horizontal">
            <Grid
              Width="{StaticResource MediumFontSize}"
              Height="{StaticResource MediumFontSize}"
              Margin="0,0,8,0"
              VerticalAlignment="{TemplateBinding VerticalAlignment}">
              <Ellipse
                Fill="{StaticResource WhiteGray}"
                Stroke="Transparent"
                StrokeThickness="2" />
              <Ellipse
                x:Name="CheckedCircle"
                Width="{StaticResource SmallFontSize}"
                Height="{StaticResource SmallFontSize}"
                Fill="{StaticResource BaseGray}"
                Stroke="Transparent" />
            </Grid>
            <ContentPresenter />
          </StackPanel>
          <ControlTemplate.Triggers>
            <Trigger Property="IsChecked" Value="True">
              <Setter TargetName="CheckedCircle" Property="Fill" Value="{StaticResource BaseBlue}" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
    <Style.Triggers>
      <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="ImageButton">
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="BorderBrush" Value="{StaticResource BaseBlue}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="VerticalAlignment" Value="Stretch"/>
        <Setter Property="Margin" Value="{StaticResource TinySpace}"/>
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="RadioButton">
              <Border
                x:Name="Border"
                Margin="{TemplateBinding Margin}"
                Padding="{TemplateBinding Padding}"
                Background="{TemplateBinding Background}"
                BorderBrush="{TemplateBinding BorderBrush}"
                BorderThickness="{TemplateBinding BorderThickness}"
                CornerRadius="{StaticResource BaseRadius}">
                <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                  <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                  </Grid.RowDefinitions>
                  <StackPanel
                    x:Name="Image"
                    Grid.Row="0"
                    Width="{StaticResource XXLFontSize}"
                    Height="{StaticResource XXLFontSize}"
                    Background="Red" />
                  <StackPanel HorizontalAlignment="Center" Grid.Row="1" >
                    <ContentPresenter/>
                  </StackPanel>
                </Grid>
              </Border>
              <ControlTemplate.Triggers>
                <Trigger Property="IsChecked" Value="True">
                  <Setter TargetName="Border" Property="Background" Value="{StaticResource WhiteGray}"/>
                  <Setter Property="Effect">
                    <Setter.Value>  
                      <DropShadowEffect
                        BlurRadius="30"
                        Opacity="0.15"
                        ShadowDepth="6" />
                    </Setter.Value>
                  </Setter>
                </Trigger>
              </ControlTemplate.Triggers>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </DataTrigger>
    </Style.Triggers>
  </Style>

  <Style TargetType="TextBlock">
    <Setter Property="FontSize" Value="{StaticResource BaseFontSize}" />
    <Style.Triggers>
      <Trigger Property="Tag" Value="Header">
        <Setter Property="Foreground" Value="{StaticResource DarkGray}" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="FontSize" Value="{StaticResource MediumFontSize}" />
      </Trigger>
    </Style.Triggers>
  </Style>
  <Style TargetType="Label">
    <Setter Property="FontSize" Value="{StaticResource BaseFontSize}" />
  </Style>
  <Style TargetType="Button" x:Key="BaseButton">
    <Setter Property="FontSize" Value="{StaticResource BaseFontSize}" />
    <Setter Property="Background" Value="{StaticResource WhiteGray}" />
    <Setter Property="Foreground" Value="{StaticResource DarkBlue}" />
    <Setter Property="Padding" Value="20,10" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="BorderBrush" Value="{StaticResource BaseGray}" />
    <Setter Property="Effect">
      <Setter.Value>
        <DropShadowEffect
          BlurRadius="6"
          Opacity="0.1"
          ShadowDepth="4" />
      </Setter.Value>
    </Setter>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border
            Padding="{TemplateBinding Padding}"
            Background="{TemplateBinding Background}"
            BorderBrush="{TemplateBinding BorderBrush}"
            BorderThickness="{TemplateBinding BorderThickness}"
            CornerRadius="{StaticResource BaseRadius}">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
    <Style.Triggers>
      <Trigger Property="Tag" Value="Success">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource BaseGreen}" />
        <Setter Property="BorderBrush" Value="{StaticResource BaseGreen}" />
      </Trigger>
      <Trigger Property="Tag" Value="Accent">
        <Setter Property="Background" Value="{StaticResource BaseBlue}" />
        <Setter Property="Foreground" Value="{StaticResource BaseWhite}" />
        <Setter Property="BorderThickness" Value="0" />
      </Trigger>
      <Trigger Property="IsPressed" Value="True">
        <Setter Property="Background" Value="{DynamicResource GrisClaro}" />
      </Trigger>
      <MultiTrigger>
        <MultiTrigger.Conditions>
          <Condition Property="IsPressed" Value="True" />
          <Condition Property="Tag" Value="Success" />
        </MultiTrigger.Conditions>
        <Setter Property="Background" Value="{DynamicResource VerdeBlanco}" />
      </MultiTrigger>
      <MultiTrigger>
        <MultiTrigger.Conditions>
          <Condition Property="IsPressed" Value="True" />
          <Condition Property="Tag" Value="Accent" />
        </MultiTrigger.Conditions>
        <Setter Property="Background" Value="{DynamicResource AzulBlanco}" />
      </MultiTrigger>
    </Style.Triggers>
  </Style>
  <Style TargetType="Button" BasedOn="{StaticResource BaseButton}"></Style>
  <Style TargetType="Grid">
    <!--
    <Setter Property="Background" Value="{StaticResource BaseBackground}"/>
    -->
    <Style.Triggers>
      <Trigger Property="Tag" Value="SmallSpace" />
    </Style.Triggers>
  </Style>
  <Style TargetType="Window">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Foreground" Value="{StaticResource DarkGray}" />
    <Setter Property="WindowStyle" Value="None" />
    <Setter Property="AllowsTransparency" Value="True" />
  </Style>
  <Style TargetType="DockPanel">
    <Setter Property="VerticalAlignment" Value="Center"/>
  </Style>
  <Style TargetType="Border">
    <Style.Triggers>
      <Trigger Property="Tag" Value="FakeWindow">
        <Setter Property="ClipToBounds" Value="True" />
        <Setter Property="Background" Value="{StaticResource Blanco}" />
        <Setter Property="CornerRadius" Value="{StaticResource BaseRadius}" />
      </Trigger>
      <Trigger Property="Tag" Value="Footer">
        <Setter Property="Padding" Value="{StaticResource MediumSpace}" />
        <Setter Property="Background" Value="{StaticResource Blanco}" />
        <Setter Property="CornerRadius" Value="{StaticResource BaseRadius-Bottom}" />
        <Setter Property="Effect">
          <Setter.Value>
            <DropShadowEffect
              BlurRadius="6"
              Direction="90"
              Opacity="0.1"
              ShadowDepth="4"
              Color="Gray" />
          </Setter.Value>
        </Setter>
      </Trigger>
      <Trigger Property="Tag" Value="High">
        <Setter Property="Background" Value="{StaticResource WhiteGray}" />
        <Setter Property="Padding" Value="{StaticResource MediumSpace}" />
        <Setter Property="CornerRadius" Value="{StaticResource BaseRadius-Top}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="BorderBrush" Value="{StaticResource BaseGray}" />
      </Trigger>
    </Style.Triggers>
  </Style>
  <Style TargetType="StackPanel">
    <Setter Property="Background" Value="{StaticResource BaseBackground}"/>
    <Style.Triggers>
      <Trigger Property="Tag" Value="Main">
        <Setter Property="Margin" Value="{StaticResource MediumSpace}" />
      </Trigger>
    </Style.Triggers>
  </Style>
  <Style TargetType="TextBox">
    <Setter Property="VerticalAlignment" Value="Center" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Padding" Value="0,10" />
    <Setter Property="BorderBrush" Value="{StaticResource BaseGray}" />
    <Setter Property="Foreground" Value="{StaticResource DarkBlue}" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="TextBox">
          <Border
            Margin="0"
            Padding="0"
            Background="{TemplateBinding Background}"
            BorderBrush="{TemplateBinding BorderBrush}"
            BorderThickness="0,0,0,1">
            <ScrollViewer
              x:Name="PART_ContentHost"
              Margin="{TemplateBinding Margin}"
              Padding="{TemplateBinding Padding}"
              HorizontalScrollBarVisibility="Hidden"
              VerticalScrollBarVisibility="Hidden" />
          </Border>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
    <Style.Triggers>
      <Trigger Property="IsFocused" Value="True">
        <Setter Property="BorderBrush" Value="{StaticResource BaseBlue}" />
      </Trigger>
    </Style.Triggers>
  </Style>
</ResourceDictionary>