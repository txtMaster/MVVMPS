<UserControl xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="./Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
      <Grid VerticalAlignment="Stretch">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>
    <DockPanel Grid.Row="0">
      <TextBlock FontSize="20" Text="{Binding StepM.Title, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}" />
    </DockPanel>
    <Grid Grid.Row="1">
      <Grid.RowDefinitions>
        <RowDefinition Height="*" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>
      <RadioButton 
      Tag="ImageButton"
      GroupName="SystemName" 
      Grid.Column="0" Grid.Row="0"
      IsChecked="True">
        VisualCont
      </RadioButton>
      <RadioButton 
      Tag="ImageButton"
      Grid.Column="1" Grid.Row="0"
      GroupName="SystemName">VisualPlan</RadioButton>
      <RadioButton 
      Tag="ImageButton"
      Grid.Column="2" Grid.Row="0"
      GroupName="SystemName">Visual ERP</RadioButton>
      <RadioButton 
      Tag="ImageButton"
      Grid.Column="0" Grid.Row="1"
      GroupName="SystemName">VisualCont 11.5</RadioButton>
    </Grid>
    <StackPanel
      Grid.Row="2"
      HorizontalAlignment="Center"
      Orientation="Horizontal">
      <RadioButton
        Content="Maquina Principal"
        GroupName="Mode"
        IsChecked="{Binding IsMain, Mode=TwoWay}" />
      <RadioButton
        Content="Maquina de red"
        GroupName="Mode"
        IsChecked="{Binding IsNet, Mode=TwoWay}" />
    </StackPanel>
  </Grid>
</UserControl>
