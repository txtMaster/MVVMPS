<Window
    ResizeMode="NoResize"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="SPA MVVM"
    Width="700"
    Height="500">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="./Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <!--BasedOn="{StaticResource BaseButton}"-->
            <Style
                x:Key="HiddenButton"
                BasedOn="{StaticResource BaseButton}"
                TargetType="Button">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding CurrentStep.StepM.BeforeStepText}" Value="">
                        <Setter Property="Visibility" Value="Hidden" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </Window.Resources>
    <Border Tag="FakeWindow">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Border Tag="High">
                <DockPanel
                    Name="header"
                    Grid.Row="0"
                    LastChildFill="False"
                    Tag="Header">
                    <TextBlock 
                    VerticalAlignment="Center"
                    Tag="Header"
                    Text="VisualCont Installer - "/>
                    <TextBlock
                        Margin="{StaticResource SmallSpace}"
                        VerticalAlignment="Center"
                        Tag="Header"
                        Text="{Binding CurrentStep.StepM.Title, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}" />
                    <Button
                        Name="closeBtn"
                        Content="close"
                        DockPanel.Dock="Right" />
                </DockPanel>
            </Border>
            <StackPanel
                Name="main"
                Grid.Row="1"
                VerticalAlignment="Stretch"
                Background="Aqua"
                Tag="Main">
                <ContentControl Content="{Binding CurrentView}" />
            </StackPanel>
            <Border
                Grid.Row="2"
                Padding="{StaticResource MediumSpace}"
                Tag="Footer">
                <DockPanel
                    Name="buttons"
                    LastChildFill="False"
                    Tag="Footer">
                    <Button
                        Name="PrevBtn"
                        Command="{Binding PreviousCommand}"
                        Content="{Binding CurrentStep.StepM.BeforeStepText, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"
                        DockPanel.Dock="Left"
                        Style="{StaticResource HiddenButton}"
                        Tag="Success" />
                    <Button
                        Name="NextBtn"
                        Command="{Binding NextCommand}"
                        Content="{Binding CurrentStep.StepM.NextStepText, Mode=OneWay, UpdateSourceTrigger=Explicit}"
                        DockPanel.Dock="Right"
                        Tag="Accent" />
                </DockPanel>
            </Border>
        </Grid>
    </Border>
</Window>
